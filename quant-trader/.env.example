# ─────────────────────────────────────────────────────────────────────────────
# QuantexPro — Environment Variables
# Copy to .env and fill in your values
#   cp .env.example .env
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════════════
# TRADING MODE
# ════════════════════════════════════════════════════════════════════════════
# Options: BACKTEST, PAPER_TRADE, LIVE_TRADE
TRADING_MODE=BACKTEST

# ════════════════════════════════════════════════════════════════════════════
# SYMBOL & STRATEGY
# ════════════════════════════════════════════════════════════════════════════
SYMBOL=AAPL
STRATEGY=ma_crossover
BAR_TYPE=5Min
STARTING_CASH=100000

# ════════════════════════════════════════════════════════════════════════════
# BROKER CREDENTIALS (Alpaca)
# Sign up: https://alpaca.markets
# Paper URL: https://paper-api.alpaca.markets
# ════════════════════════════════════════════════════════════════════════════
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ════════════════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL)
# ════════════════════════════════════════════════════════════════════════════
DB_HOST=postgres
DB_PORT=5432
DB_NAME=quantexpro
DB_USER=quantex
DB_PASSWORD=changeme_in_production

# ════════════════════════════════════════════════════════════════════════════
# REDIS (Order cache + Pub/Sub)
# ════════════════════════════════════════════════════════════════════════════
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ════════════════════════════════════════════════════════════════════════════
# RISK PARAMETERS
# ════════════════════════════════════════════════════════════════════════════
MAX_DRAWDOWN_PCT=0.15
MAX_POSITION_RISK=0.02
MAX_PORTFOLIO_RISK=0.30
MAX_OPEN_POSITIONS=5
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.05

# ════════════════════════════════════════════════════════════════════════════
# NOTIFICATIONS & ALERTS
# ════════════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ════════════════════════════════════════════════════════════════════════════
# MONITORING
# ════════════════════════════════════════════════════════════════════════════
PROMETHEUS_PORT=8001
LOG_LEVEL=INFO
SENTRY_DSN=                          # Optional error tracking

# ════════════════════════════════════════════════════════════════════════════
# SCHEDULER
# ════════════════════════════════════════════════════════════════════════════
SCHEDULER_ENABLED=false
SCHEDULER_CHECK_INTERVAL_MINUTES=15

# ════════════════════════════════════════════════════════════════════════════
# GRAFANA
# ════════════════════════════════════════════════════════════════════════════
GRAFANA_PASSWORD=admin